PORT=5000
NODE_ENV=development

MONGO_URI=your_mongodb_connection_string
CLIENT_URL=http://localhost:5173

ACCESS_TOKEN_SECRET=replace_with_a_long_random_access_secret
REFRESH_TOKEN_SECRET=replace_with_a_long_random_refresh_secret
ACCESS_TOKEN_EXPIRES=15m
REFRESH_TOKEN_EXPIRES=7d

COOKIE_SECURE=false
COOKIE_SAME_SITE=lax

# Optional: use public DNS resolvers if Node.js cannot resolve MongoDB Atlas SRV records locally.
DNS_SERVERS=
